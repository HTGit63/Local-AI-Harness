FROM node:22-alpine@sha256:4d64b49e6c891c8fc821007cb1cdc6c0db7773110ac2c34bf2e6960adef62ed3 AS deps

WORKDIR /app

COPY package.json package-lock.json ./
COPY apps/api/package.json ./apps/api/package.json
COPY apps/cli/package.json ./apps/cli/package.json
COPY apps/web/package.json ./apps/web/package.json
COPY packages/approval-workflow/package.json ./packages/approval-workflow/package.json
COPY packages/core/package.json ./packages/core/package.json
COPY packages/doctor/package.json ./packages/doctor/package.json
COPY packages/model-adapter/package.json ./packages/model-adapter/package.json
COPY packages/planner/package.json ./packages/planner/package.json
COPY packages/prompt-recipes/package.json ./packages/prompt-recipes/package.json
COPY packages/repo-indexer/package.json ./packages/repo-indexer/package.json
COPY packages/session-store/package.json ./packages/session-store/package.json
COPY packages/skills/package.json ./packages/skills/package.json
COPY packages/tool-runtime/package.json ./packages/tool-runtime/package.json
COPY packages/trace-bus/package.json ./packages/trace-bus/package.json
COPY packages/workspace-policy/package.json ./packages/workspace-policy/package.json

RUN npm ci --no-audit --no-fund

FROM deps AS build

COPY apps/api ./apps/api
COPY apps/cli ./apps/cli
COPY packages ./packages
COPY third_party/agency-agents ./third_party/agency-agents

RUN npm run build:packages \
 && npm run build --workspace @local-harness/api \
 && npm run build --workspace @local-harness/cli

FROM node:22-alpine@sha256:4d64b49e6c891c8fc821007cb1cdc6c0db7773110ac2c34bf2e6960adef62ed3 AS runtime

WORKDIR /app

RUN apk add --no-cache git

ENV NODE_ENV=production
ENV API_HOST=0.0.0.0
ENV API_PORT=3001
ENV HARNESS_WORKSPACE_ROOT=/workspace
ENV OPENAI_API_KEY=ollama

COPY --from=deps /app/package.json /app/package-lock.json ./
COPY --from=deps /app/node_modules ./node_modules
COPY --from=build /app/apps/api/dist ./apps/api/dist
COPY --from=build /app/apps/cli/dist ./apps/cli/dist
COPY --from=build /app/packages ./packages

EXPOSE 3001

CMD ["node", "apps/api/dist/server.js"]
